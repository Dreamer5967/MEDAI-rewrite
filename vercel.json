{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.py" },
    {
      "src": "/(.*)",
      "dest": "frontend/$1",
      "headers": { "cache-control": "public, max-age=0, must-revalidate" }
    }
  ],
  "env": {
    "ENVIRONMENT": "production"
  }
}
